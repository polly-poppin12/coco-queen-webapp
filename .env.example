# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Postgres connection string (e.g. from Neon, Supabase, or any
# managed Postgres provider). REQUIRED. The app will not start without this.
#
# Why this exists: Cloud Run's filesystem is ephemeral — anything written to
# local disk (like the old data.json flat-file store) is wiped on every
# container restart, redeploy, or scale-to-zero cycle. That was the root
# cause of accounts/orders disappearing and logins failing unpredictably.
# A real Postgres database is what actually persists this data.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# REQUIRED before first boot. These create the initial owner/admin accounts.
# Unlike the old behavior, the app will now refuse to start (rather than
# silently generating an unrecoverable random password) if these are unset
# on first boot — that silent-random-password behavior is what caused
# accounts to become permanently unreachable.
OWNER_BOOTSTRAP_PASSWORD="CHANGE_ME_TO_A_LONG_PRIVATE_PASSWORD"
ADMIN_BOOTSTRAP_PASSWORD="CHANGE_ME_TO_A_LONG_PRIVATE_PASSWORD"

# HMAC_SECRET: Used to sign sensitive API requests (checkout, payment, admin ops).
# If omitted, a random secret is generated on each server start. For production,
# set a fixed value so that clients can pre-compute valid signatures.
# NOTE: The frontend CartDrawer sends HMAC-signed checkout requests automatically.
HMAC_SECRET="CHANGE_ME_TO_A_RANDOM_SECRET_KEY"

# DANGER: Set to 'true' ONLY for local development to disable HMAC verification.
# Never set this in production. If unset or 'false', HMAC is enforced everywhere
# except when NODE_ENV=development.
# DISABLE_HMAC=false

# DATABASE_SSL_CA: Path to the CA certificate file for Postgres SSL verification.
# Required when rejectUnauthorized: true (production). For Neon, download the
# CA cert from your Neon dashboard.
# DATABASE_SSL_CA_PATH="./neon-ca.pem"

# DISABLE_SSL_VERIFY: Set to 'true' ONLY for local development to skip Postgres
# SSL certificate validation. Never use in production.
# DISABLE_SSL_VERIFY=false

